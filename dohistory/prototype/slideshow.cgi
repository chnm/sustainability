#!/usr/local/bin/perl5## slideshow -- Ken Shan <ken@digitas.harvard.edu>## Film Study Center Web site slide show CGI script.require 5;use strict;use Ken::Cgi;use Ken::Url;use Ken::Pre;use Ken::CgiDie;my $cgi = Ken::Cgi::GetFields();        # CGI argumentsmy $staging = (($ENV{SCRIPT_NAME} =~ m!/staging/!)    ? '/staging' : '');                 # Directory infix for stagingmy $dir = "/u/barlow$staging/slideshow";# Data directorymy ($defn_fn, $temp_fn) = @{$cgi}{qw(show temp)};$defn_fn =~ tr/-_.0-9A-Za-z//cd;        # Definition file name$defn_fn = 'slideshow' if $defn_fn eq '';$temp_fn =~ tr/-_.0-9A-Za-z//cd;        # Template file name$temp_fn = 'slideshow' if $temp_fn eq '';my $defn_path = "$dir/$defn_fn.def";    # Full path of definition filemy $temp_path = "$dir/$temp_fn.html";   # Full path of template filemy $url_prefix = "http://www.digitas.harvard.edu/~barlow";my $url_root   = "$url_prefix$staging";my $url_cgi    = "$url_prefix/cgi-bin$staging/slideshow";my $url_images = $url_root;# If there's no "seq" argument, re-randomize.# If there is a "seq" argument, get the list of slides from it.my @seq;if ($cgi->{seq} eq ''){    my $init;                           # Whether $cgi->{init} has been seen    open DEFN, $defn_path        or CgiDie "Cannot open definition file $defn_path: $!\n";    while (<DEFN>)    {        $_ = $` if /#/;        $cgi->{init} eq $& and $init = 1            or splice @seq, int rand @seq, 0, $& while /[\-\w]+/g;    }    close DEFN;    unshift @seq, $cgi->{init} if $init;}else{    @seq = ($cgi->{seq} =~ /[\-\w]+/g);}# Read abbreviation mapping file.open MAP, "$dir/map" or CgiDie "Cannot open map file: $!\n";my %title_map;my %collab_map;while (<MAP>){    s/^\s+//; s/\s+$//;    my ($code, $collabs, $title) = split /\s*=\s*/, $_, -1 or next;    $title_map{$code} = $title;    $collab_map{$code} = [split ' ', $collabs];}close MAP;sub link_to_dir{    my $image = $_[0];    my $code = $_[1] || substr($image, 0, 3);    return "$url_cgi?show=${code}sshow&temp=${code}sshow&init=$image";}# List of project codes that are not yet ready for Web display.my %no_link_codes;@no_link_codes{qw(NDV MAS RGG ALW)} = ();# Read template file and translate embedded commands.open TEMP, $temp_path    or CgiDie "Cannot open template file $temp_path: $!\n";print "Content-type: text/html\n\n";while (<TEMP>){    s{\*\*\*(.+?)\*\*\*}{        my @stuff = split /_/, $1, -1;        if ($stuff[1] eq 'left' or $stuff[1] eq 'right')        {                               # slide_<left|right>_n_<show>_<temp>            my $offset = ($stuff[1] eq 'left') ? (@seq - $stuff[2]) : $stuff[2];            $url_cgi . '?show=' . ($stuff[3] eq '' ? $defn_fn : $stuff[3])                     . '&temp=' . ($stuff[4] eq '' ? $temp_fn : $stuff[4])                     . '&seq=' . join '+',                         @seq[($offset .. @seq-1), (0 .. $offset-1)];        }        elsif ($stuff[1] eq 'map')        {                               # slide_map_n (top-level caption map)            my ($width, $height) = @stuff[3, 4];            my $code = substr($seq[$stuff[2]], 0, 3);            my @link = ($code, @{$collab_map{$code}});            my @ret;            for (my $i = 0; $i < @link; ++$i)            {                push @ret, '<area shape=rect coords="0,',                    int($height * $i / @link), ',', $width, ',',                    int($height * ($i+1) / @link) - 1, '" href="',                    link_to_dir($seq[$stuff[2]], $link[$i]), "\">\n"                    unless exists $no_link_codes{$link[$i]};            }            join '', @ret;        }        elsif ($stuff[1] eq 'desct')        {                               # slide_desct_n (bigimg caption text)            if (open CAPTION, "$dir/caption/$seq[$stuff[2]].txt")            {                local $/ = undef;                my $caption = Ken::Pre::Escape(<CAPTION>);                close CAPTION;                $caption;            }            else { '' }        }        elsif ($stuff[1] eq 'desca')        {                               # slide_desca_n (bigimg caption anchors)            my $image = $seq[$stuff[2]];            my $code = substr($image, 0, 3);            my $project_name = $title_map{$code};            unless (exists $no_link_codes{$code})            {                $project_name =~ s/\s+\[|\Z/<\/a>$&/;                $project_name = '<a href="'                    . link_to_dir($image, $code) . '">' . $project_name;            }            my @ret = ('from ', $project_name);            my $and;            foreach my $collab (@{$collab_map{$code}})            {                push @ret, ($and ? ' and ' : ' by '),                    exists $no_link_codes{$collab}                    ? ($title_map{$collab})                    : ('<a href="', link_to_dir($image, $collab), '">',                        $title_map{$collab}, '</a>');                $and = 1;            }            join '', @ret;        }        else        {            ($stuff[1] eq 'small')      # slide_small_n (small image)          ? "$url_images/images2/$seq[$stuff[2]].GIF"          : ($stuff[1] eq 'large')      # slide_large_n (large image)          ? "$url_images/images4/$seq[$stuff[2]].JPG"          : ($stuff[1] eq 'desci')      # slide_desci_n (top-level caption)          ? "$url_images/images3/".substr($seq[$stuff[2]], 0, 3).".gif"          : ($stuff[1] eq 'descc')      # slide_descc_n (collab-level caption)          ? "$url_images/images3/".substr($seq[$stuff[2]], 0, 3)."_smcap.gif"          : ($stuff[1] eq 'descp')      # slide_descp_n (project-level caption)          ? "$url_images/images3/$seq[$stuff[2]].gif"          : ($stuff[1] eq 'link')       # slide_link_n (link by 3-letter code)          ? link_to_dir($seq[$stuff[2]])          : ($stuff[1] eq 'linkl')      # slide_linkl_n (link to bigimg)          ? "$url_cgi?show=bigimg&temp=bigimg&seq=$seq[$stuff[2]]&back="                . Ken::Url::Escape("$url_cgi?show=$defn_fn&temp=$temp_fn&seq="                    . join '+', @seq)          : ($stuff[1] eq 'back')       # slide_back (back-up link in bigimg)          ? $cgi->{back} || $ENV{HTTP_REFERER}          : ($stuff[1] eq 'url')        # slide_url_root (root URL)          ? $url_root          : $&;                         # unknown directive        }    }ge;    print;}close TEMP;