#!/usr/bin/perl## midwife/markle -- Ken Shan <ken@digitas.harvard.edu>require 5;#use strict;use Ken::Cgi;use Ken::Url;use Ken::Pre;use Time::CTime;# Are we midwife or are we markle?my $identity = $0;   $identity = substr($identity, rindex($identity, '/') + 1);my $identity_url = $identity;   $identity = substr($identity, rindex($identity, '_') + 1);   $identity =~ s/\.cgi//;die "Identity [". $identity . "] not midwife, markle or grantapp"    if $identity ne 'midwife'    && $identity ne 'markle'    && $identity ne 'grantapp';# Global constantsmy $template_root = "/home/WWW/dohistory.com/htdocs/prototype/$identity/templates";my $session_root = "/home/WWW/dohistory.com/htdocs/prototype/$identity/sessions";my $url_root = "http://www.dohistory.org/prototype";my $url_cgi = "$url_root/$identity_url";my $url_lit = "$url_root/$identity";# CGI variable hash, reference theretomy $cgi;# Session IDmy $session_id;# Persistent session variablesmy %session_vars;my $session_vars_dirty;# The eventual output pagemy @output;# Stack of template files being parsedmy @template_file;my @template_dir;my @template_line;# Handle fatal errorsub mwError{    my $message = $_[0];    print "Content-Type: text/html\n\n";    print "<h1>Error</h1>\n", Ken::Pre::Escape($message), "<p>\n";    if (@template_file)    {        print "Template stack:<ul compact>\n";        for (my $i = 0; $i < @template_file; ++$i)        {            print "<li>$template_file[$i] line $template_line[$i]</li>\n";        }        print "</ul>\n";    }    exit 1;}# Extract directory portion from pathsub mwPathDir{    $_[0] =~ m{^(.*)/};    $1;}# Resolve relative pathsub mwPathAbs{    my $ret = $template_dir[-1];    foreach my $arg (@_)    {        $ret = substr($arg, 0, 1) eq '/' ? $arg : "$ret/$arg";    }    1 while $ret =~ s{/\.?/|/[^./][^/]*/\.\./}{/};    $ret;}# Return URL for the top-level pagesub mwTopUrl{    "$url_cgi$template_file[0]?sid=$session_id&from=$template_file[0]";}# Return URL for the current pagesub mwThisUrl{    "$url_cgi$template_file[-1]?sid=$session_id&from=$template_file[0]";}# Return URL for a subsequent pagesub mwThatUrl{    my $path = mwPathAbs($_[0]);    "$url_cgi$path?sid=$session_id&from=$template_file[0]";}# Get CGI input fieldsub mwGetCgi{    $cgi->{$_[0]};}# Get session variablesub mwGetSsv{    $session_vars{$_[0]};}# Set session variablesub mwSetSsv{    $session_vars{$_[0]} = $_[1];    $session_vars_dirty = 1;}# Escape a string using HTML character entitiessub mwEscape{    Ken::Pre::Escape($_[0]);}# Add stuff to output pagesub mwOutput{    push @output, @_;}# Parse the specified template filesub mwInclude{    my $template_file = $_[0];    my $template_full = "$template_root/$template_file";    # Read the template file    -f($template_full)        or mwError("Template file $template_file not found or extraordinary");    open TEMPLATE, $template_full        or mwError("Cannot open template file $template_file: $!");    my $template;    {        local $/ = undef;        $template = <TEMPLATE>;    }    close TEMPLATE;    # Push the current template file    push @template_file, $template_file;    push @template_dir, mwPathDir($template_file);    push @template_line, 1;    # Conditional stack    my @cond = 1; # 1=true, 0=false, -1=skipping else, -2=skipping false above    # Perform dynamic replacements    while ($template =~ m{\G(?:        \<\? (.*?) \?\> | # Conditional "if"/"endif"        \<\: (.*?) \:\> | # Conditional "elsif"/"else"        \<\[ (.*?) \]\> | # Eval and insert result        \<\{ (.*?) \}\> | # Eval and discard result        \<\< (.*?) \>\> | # Point to subsequent URL        \<\+ (.*?) \+\> | # Include other template file        ([^<]+|<) )}sxg)  # Literal HTML    {        my $stuff = $+;        if (defined $1)        {            if ($stuff =~ /\S/)            {   # If                push @cond, $cond[-1] == 1 ? eval($stuff) ? 1 : 0 : -2;            }            else            {   # Endif                @cond > 1 or mwError("Endif without matching if");                pop @cond;            }        }        elsif (defined $2)        {            if ($stuff =~ /\S/)            {   # Elsif                @cond > 1 or mwError("Elsif without matching if");                if ($cond[-1] == 1) { $cond[-1] = -1 }                elsif ($cond[-1] == 0) { $cond[-1] = eval($stuff) ? 1 : 0 }            }            else            {                # Else                @cond > 1 or mwError("Else without matching if");                if ($cond[-1] == 1) { $cond[-1] = -1 }                elsif ($cond[-1] == 0) { $cond[-1] = 1 }            }        }        elsif ($cond[-1] != 1) { }        elsif (defined $3) { mwOutput(eval($stuff)) }        elsif (defined $4) { eval($stuff) }        elsif (defined $5)        {            mwOutput($stuff =~ /\S/ ? mwThatUrl($stuff) : mwTopUrl());        }        elsif (defined $6)        {            my $file = $stuff;            $file =~ s/^\s+//;            $file =~ s/\s+$//;            mwInclude($file);        }        else { mwOutput($stuff) }        $template_line[-1] += ($stuff =~ tr/\n/\n/);    }    # Pop stuff off the stack    pop @template_file;    pop @template_dir;    pop @template_line;}# Get CGI input fields and clean them up$cgi = Ken::Cgi::GetFields();while (my ($key, $val) = each %$cgi){    $val =~ tr/\0\n -~\200-\376//cd;    $cgi->{$key} = $val;}# Determine top-level template file namemy $path_info = Ken::Url::Unescape($ENV{PATH_INFO});my $top_template_file = join '', ($path_info =~ m{/[^./][^/]*}g);# Special case: graphics, sound and movie files should not be parsed at allif ($top_template_file =~ /\.(gif|jpe?g?|au|aiff?|mov)$/si){    print "Location: $url_lit$top_template_file\n\n";    exit 0;}# Print CGI output headerprint strftime(<<'END', gmtime);Content-type: text/htmlDate: %a, %e %h %Y %X GMTExpires: %a, %e %h %Y %X GMTCache-Control: no-cacheEND# Get current session ID and associated info, or generate new session ID$session_id = $cgi->{sid};$session_id =~ tr/-A-Za-z0-9//cd;if ($session_id ne ''){    if (open SESSION, "<$session_root/$session_id\0")    {        local $/ = undef;        Ken::Cgi::SplitFields \%session_vars, scalar(<SESSION>);        close SESSION;    }}else { $session_id = time . '-' . $$ }# Install fatal error handler$SIG{'__DIE__'} = \&mwError;# Include the top-level template filemwInclude($top_template_file);# Write out session info if dirtyif ($session_vars_dirty){    if (%session_vars)    {        open SESSION, ">$session_root/$session_id\0"            or mwError("Cannot save session info file $session_id: $!");        my $amp;        while (my ($key, $val) = each %session_vars)        {            $amp and print SESSION '&' or $amp = 1;            print SESSION Ken::Url::Escape($key), '=', Ken::Url::Escape($val);        }        close SESSION;    }    else    {        unlink "$session_root/$session_id"            or mwError("Cannot unlink session info file $session_id: $!");    }}# Produce outputprint @output;