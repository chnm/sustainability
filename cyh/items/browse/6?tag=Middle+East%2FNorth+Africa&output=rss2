                                    <div class="element-text">http://www.eternalegypt.org</div>
                    </div><!-- end element -->
            <div id="website-review-item-type-metadata-website-creator" class="element">
        <h3>Website Creator</h3>
                                    <div class="element-text">Egyptian Center for Documentation of Cultural and Natural Heritage (CultNat) and IBM</div>
                    </div><!-- end element -->
            <div id="website-review-item-type-metadata-date-of-review" class="element">
        <h3>Date of Review</h3>
