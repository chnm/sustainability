        <h3>Title</h3>
                                    <div class="element-text">Annual Report on Native Affairs, 1874 [Government Report]</div>
                    </div><!-- end element -->
            <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
                    <div class="element-text-empty">[no text]</div>
