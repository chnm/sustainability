    <item>
      <title><![CDATA[At the Crossroads: Where African American Studies and Digital Humanities Meet]]></title>
      <link>https://harambeecity.lib.miamioh.edu/items/show/58</link>
      <description><![CDATA[<div class="element-set">
        <h2>Dublin Core</h2>
            <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                    <div class="element-text">At the Crossroads: Where African American Studies and Digital Humanities Meet</div>
            </div><!-- end element -->
        <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
                    <div class="element-text">CORE, Black Power, Economic Development, Harambee City Website, public history, black studies, digital humanities</div>
            </div><!-- end element -->
        <div id="dublin-core-description" class="element">
        <h3>Description</h3>
                    <div class="element-text">This talk discusses my personal journey from public history to digital humanities.  It reviews the conceptual framework for this website and presents my perspective on how digital humanities can reflect the spirit of black studies&#039; theoretical sensibilities.</div>
            </div><!-- end element -->
        <div id="dublin-core-creator" class="element">
        <h3>Creator</h3>
                    <div class="element-text">Nishani Frazier</div>
            </div><!-- end element -->
        <div id="dublin-core-source" class="element">
        <h3>Source</h3>
