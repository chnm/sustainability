        <h3>Title</h3>
                                    <div class="element-text"><em>Manuelita</em> [Painting]</div>
                    </div><!-- end element -->
            <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
                    <div class="element-text-empty">[no text]</div>
