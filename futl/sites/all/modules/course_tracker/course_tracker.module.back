function course_tracker_form_alter(&$form, &$form_state, $form_id) {
    //dprint_r($form);
    if ($form_id == 'user_profile_form') {
        $form['#submit'][] = 'course_tracker_submit_handler';
    }
}

function course_tracker_submit_handler(&$form, &$form_state) {
    $form_state['redirect'] = 'content/hist-689-teaching-and-learning-history-digital-age';
}


