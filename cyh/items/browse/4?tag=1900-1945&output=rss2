        <div id="website-review-item-type-metadata-website-url" class="element">
        <h3>Website URL</h3>
                                    <div class="element-text">http://digital.library.cornell.edu/s/sea/index.php</div>
                    </div><!-- end element -->
            <div id="website-review-item-type-metadata-website-creator" class="element">
        <h3>Website Creator</h3>
                                    <div class="element-text">Cornell University Library, John M. Echols Collection</div>
                    </div><!-- end element -->
