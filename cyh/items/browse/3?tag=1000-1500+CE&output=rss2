      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text">Testament of a Father during the Black Death [Will]</div>
                    </div><!-- end element -->
            <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
