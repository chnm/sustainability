        <h3>Title</h3>
                                    <div class="element-text">&quot;How Some Children Played at Slaughtering&quot; [Children&#039;s Literature]</div>
                    </div><!-- end element -->
            <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
