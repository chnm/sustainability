      <link>https://cyh.rrchnm.org/items/show/154</link>
      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text">Children in the Slave Trade [Table]</div>
                    </div><!-- end element -->
