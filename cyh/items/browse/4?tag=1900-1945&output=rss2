      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text">Samoan Baby and Baby-Tender [Anthropology Text]</div>
                    </div><!-- end element -->
