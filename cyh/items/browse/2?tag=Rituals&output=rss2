      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text">Child with Purple Plastic Doll near Kumasi, Ghana [Photograph]</div>
                    </div><!-- end element -->
