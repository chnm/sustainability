      <link>https://cyh.rrchnm.org/items/show/307</link>
      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text">Bronx Schoolyard [Graffiti]</div>
                    </div><!-- end element -->
