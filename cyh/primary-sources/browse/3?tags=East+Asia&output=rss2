      <description><![CDATA[<div class="element-set">
    <h2>Dublin Core</h2>
        <div id="dublin-core-title" class="element">
        <h3>Title</h3>
                                    <div class="element-text"><em>Meng Ch'iu</em>, K'uang Heng bores a hole in the wall Sun Ching shuts his door [Literary Excerpt]</div>
                    </div><!-- end element -->
