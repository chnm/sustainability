        <div id="website-review-item-type-metadata-website-url" class="element">
        <h3>Website URL</h3>
                                    <div class="element-text">http://www.law.mq.edu.au/scnsw/</div>
                    </div><!-- end element -->
            <div id="website-review-item-type-metadata-website-creator" class="element">
