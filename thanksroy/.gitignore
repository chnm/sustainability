# .gitignore for thanksroy.org
#
# Auto-generated by multi-crawl.py from sites.toml. Edit the
# site's [[sites]] entry (or its presets) in sites.toml to change
# what's ignored; do not edit this file by hand.

# Crawler-artifact subdir (logs, failures.tsv, rejected.log,
# excluded.tsv). Already covered by the parent .gitignore; listed
# here so the site dir stays self-contained if it ever moves.
/.crawl/

# exclude_dirs — wget never fetched URLs under these
# paths. Listed here as defense-in-depth.
/admin/
/users/
/items/add/
/items/edit/
/collections/add/
/files/original/
**/files/original/
/files/fullsize/
**/files/fullsize/
/files/thumbnails/
**/files/thumbnails/
/files/square_thumbnails/
**/files/square_thumbnails/

# exclude_patterns — URL globs (not filesystem paths).
# Recorded as comments for traceability only.
# */output=*
# *?output=*
# *&output=*
# */browse?*sort_field=*
# *?sort_field=*
# *?sort_dir=*
# *&sort_field=*
# *&sort_dir=*
# *?advanced*
# *%3Fadvanced*
# *&advanced*
# *?tags=*&page=*
# *\"*
# *%5C%22*
