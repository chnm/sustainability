                                    <div class="element-text">Two Daughters of Akhenaten [Bas-Relief]</div>
                    </div><!-- end element -->
            <div id="dublin-core-subject" class="element">
        <h3>Subject</h3>
                    <div class="element-text-empty">[no text]</div>
